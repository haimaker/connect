{
  "name": "@haimaker/connect",
  "version": "0.1.1",
  "description": "Pure-TypeScript npx CLI that writes each supported coding agent's native config so it talks directly to api.haimaker.ai, then exits. No router, no proxy, no telemetry.",
  "license": "MIT",
  "author": "Haimaker",
  "homepage": "https://github.com/haimaker/connect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haimaker/connect.git"
  },
  "bugs": {
    "url": "https://github.com/haimaker/connect/issues"
  },
  "keywords": [
    "haimaker",
    "cli",
    "llm",
    "openai-compatible",
    "anthropic",
    "claude-code",
    "codex",
    "opencode",
    "cline",
    "hermes",
    "inference"
  ],
  "type": "commonjs",
  "bin": {
    "connect": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@types/node": "^20.17.10"
  }
}
